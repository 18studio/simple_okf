# OKF local and Docker Compose configuration.
# Copy this file to okf_mcp/rag/.env for local CLI runs.
# docker-compose.yml loads this file with env_file.
# Do not commit okf_mcp/rag/.env with local secrets.

# OKF bundle used by the MCP server when --bundle is not provided.
OKF_BUNDLE=okf

# OKF bundle to inspect/index. Relative paths are resolved from the repository root
# for local CLI runs and from /app for Docker Compose runs.
RAG_BUNDLE_DIR=okf

# Local RAG artifacts directory. Relative paths are resolved from the repository root
# for local CLI runs and from /app for Docker Compose runs.
RAG_ARTIFACTS_DIR=artifacts/rag

# Local retrieval defaults.
RAG_RETRIEVAL_RESULT_LIMIT=10
RAG_ANSWER_EVIDENCE_LIMIT=5

# Reserved for future indexed/generative RAG integration.
# Keep empty for the default Docker Compose setup: it intentionally starts no
# external OpenSearch, Qdrant, or OpenAI-dependent services.
RAG_OPENSEARCH_URL=
RAG_QDRANT_URL=
OPENAI_API_KEY=
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_DIMENSIONS=
RAG_GENERATION_MODEL=
RAG_REPHRASER_MODEL=
