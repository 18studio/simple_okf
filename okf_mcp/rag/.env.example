# OKF local and Docker Compose configuration.
# Copy this file to okf_mcp/rag/.env for local CLI runs.
# docker-compose.yml loads this file with env_file.
# Do not commit okf_mcp/rag/.env with local secrets.

# OKF bundle used by the MCP server when --bundle is not provided.
OKF_BUNDLE=okf

# OKF bundle to inspect/index. Relative paths are resolved from the repository root
# for local CLI runs and from /app for Docker Compose runs.
RAG_BUNDLE_DIR=okf

# Local RAG artifacts directory. Relative paths are resolved from the repository root
# for local CLI runs and from /app for Docker Compose runs.
RAG_ARTIFACTS_DIR=artifacts/rag

# Retrieval/evaluation defaults. Keep `local` and disabled modes for infra-free
# CLI smoke tests; use keyword/semantic/hybrid plus event/evaluation modes when
# ClickHouse/OpenSearch/Qdrant are running.
RAG_RETRIEVAL_RESULT_LIMIT=10
RAG_ANSWER_EVIDENCE_LIMIT=5
RAG_RETRIEVAL_MODE=local
RAG_EVALUATION_MODE=disabled
RAG_EVENT_STORAGE_MODE=disabled
RAG_EVALUATION_THRESHOLD=0.5
RAG_HYBRID_KEYWORD_WEIGHT=0.5
RAG_HYBRID_SEMANTIC_WEIGHT=0.5
RAG_INFRASTRUCTURE_TIMEOUT_SECONDS=10

# Required RAG infrastructure for MCP server startup readiness.
# If you already have a local okf_mcp/rag/.env, add/update the
# RAG_CLICKHOUSE_*, RAG_OPENSEARCH_*, and RAG_QDRANT_* keys from this example.
# Docker Compose service names work inside the Compose network. For host-side
# local CLI/server runs, copy this file to .env and override URLs with localhost
# equivalents such as http://127.0.0.1:8123, http://127.0.0.1:9200, and
# http://127.0.0.1:6333.
RAG_CLICKHOUSE_URL=http://clickhouse:8123
RAG_CLICKHOUSE_USER=default
RAG_CLICKHOUSE_PASSWORD=SimpleOkfLocal123!
RAG_CLICKHOUSE_DATABASE=okf_rag
RAG_CLICKHOUSE_EVENTS_TABLE=rag_events

RAG_OPENSEARCH_URL=http://opensearch:9200
RAG_OPENSEARCH_USER=
RAG_OPENSEARCH_PASSWORD=
RAG_OPENSEARCH_INDEX=okf-concepts

RAG_QDRANT_URL=http://qdrant:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=okf-concepts

# Embeddings default to deterministic local vectors for tests/dev. Replace the
# model/provider wiring in code before using external embedding services.
OPENAI_API_KEY=
RAG_EMBEDDING_MODEL=deterministic-hash-v1
RAG_EMBEDDING_DIMENSIONS=64
RAG_GENERATION_MODEL=
RAG_REPHRASER_MODEL=
