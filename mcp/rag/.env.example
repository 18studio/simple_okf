# OKF RAG local configuration.
# Copy this file to mcp/rag/.env and fill secrets locally. Do not commit mcp/rag/.env.

# OKF bundle to inspect/index. Relative paths are resolved from the repository root.
RAG_BUNDLE_DIR=okf

# Local RAG artifacts directory. Relative paths are resolved from the repository root.
RAG_ARTIFACTS_DIR=artifacts/rag

# Local retrieval defaults.
RAG_RETRIEVAL_RESULT_LIMIT=10
RAG_ANSWER_EVIDENCE_LIMIT=5

# Reserved for future indexed/generative RAG integration.
RAG_OPENSEARCH_URL=http://127.0.0.1:9200
RAG_QDRANT_URL=http://127.0.0.1:6333
OPENAI_API_KEY=your-api-key
RAG_EMBEDDING_MODEL=text-embedding-3-large
RAG_EMBEDDING_DIMENSIONS=3072
RAG_GENERATION_MODEL=gpt-4.1-mini
RAG_REPHRASER_MODEL=gpt-4.1-mini
